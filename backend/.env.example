# ─── AI ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=change-me-sk-ant-api03-xxxxx

# ─── Auth (Supabase) ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=change-me-eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...anon...
SUPABASE_SERVICE_ROLE_KEY=change-me-eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...service...
JWT_SECRET=change-me-minimum-32-characters-long-random-string

# ─── Vector DB (Qdrant) ──────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ─── Memory (Mem0) ───────────────────────────────────────────────────────────
MEM0_API_KEY=change-me-m0-xxxxx

# ─── Observability (Langfuse) ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=change-me-pk-lf-xxxxx
LANGFUSE_SECRET_KEY=change-me-sk-lf-xxxxx
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Storage ─────────────────────────────────────────────────────────────────
USE_LOCAL_STORAGE=true
# AZURE_STORAGE_CONNECTION_STRING=change-me (somente em produção)

# ─── Whisper ─────────────────────────────────────────────────────────────────
WHISPER_MODEL=small
WHISPER_CACHE_DIR=/home/app/.cache/whisper

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
CORS_ORIGINS=http://localhost:4200
