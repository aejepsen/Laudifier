# .env.example — Laudifier
# Copie para .env e preencha

# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Modelo: sonnet para laudos (mais preciso) | haiku para rascunhos rápidos
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Embeddings ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSIONS=3072

# ── Qdrant — Repositório de Laudos ────────────────────────────────────────────
QDRANT_URL=https://seu-cluster.qdrant.io
QDRANT_API_KEY=sua-chave
QDRANT_COLLECTION=laudos_medicos

# Local: docker run -p 6333:6333 qdrant/qdrant
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# ── Storage ───────────────────────────────────────────────────────────────────
USE_LOCAL_STORAGE=true              # true para dev, false para produção
LOCAL_STORAGE_PATH=./storage
# Produção: Cloudflare R2 ou Azure Blob
# S3_ENDPOINT_URL=https://...
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
S3_BUCKET_LAUDOS=laudifier-laudos
S3_BUCKET_EXPORTS=laudifier-exports

# ── Auth — Supabase ────────────────────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key
JWT_SECRET=sua-chave-jwt-longa

# ── Backend ────────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:4200

# ── Langfuse ───────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Whisper (fallback server-side) ─────────────────────────────────────────────
WHISPER_MODEL=small     # small é bom para termos médicos
WHISPER_LANGUAGE=pt

# ── Mem0 — Memory 2.0 ─────────────────────────────────────────────────────────
# Mem0 usa o MESMO Qdrant do projeto (coleção separada: laudifier_memory)
# e o MESMO Claude Haiku já configurado acima.
# Nenhuma configuração adicional obrigatória — funciona com as variáveis acima.
#
# Para usar a plataforma gerenciada Mem0 Cloud (opcional):
# MEM0_API_KEY=m0-...   ← substitui o modo self-hosted completamente
# (com MEM0_API_KEY definido, o MemoryClient é usado em vez do Memory local)
