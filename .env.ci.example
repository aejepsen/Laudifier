# .env.ci.example — segredos do GitHub Actions
# Copie para .env.ci, preencha e rode: ./scripts/sync-secrets.sh
# .env.ci está no .gitignore — NUNCA commitar valores reais.

# ─── Aproveitados do backend/.env ────────────────────────────────────────────
ANTHROPIC_API_KEY=change-me-sk-ant-api03-xxxxx
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=change-me-eyJ...
SUPABASE_SERVICE_ROLE_KEY=change-me-eyJ...
JWT_SECRET=change-me-minimum-32-characters-long
QDRANT_URL=https://your-cluster.region.aws.cloud.qdrant.io:6333
QDRANT_API_KEY=change-me-qdrant-api-key
LANGFUSE_PUBLIC_KEY=change-me-pk-lf-xxxxx
LANGFUSE_SECRET_KEY=change-me-sk-lf-xxxxx

# ─── Específicos do CI/CD ─────────────────────────────────────────────────────

# Docker Hub — hub.docker.com → Account Settings → Security → New Access Token
DOCKERHUB_USERNAME=seu-usuario-dockerhub
DOCKERHUB_TOKEN=change-me-dckr_pat_xxxxxxxxxxxx

# Azure OIDC — App Registration criado para o GitHub Actions
# az ad app create --display-name "laudifier-github-actions"
AZURE_CLIENT_ID=change-me-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_TENANT_ID=change-me-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_SUBSCRIPTION_ID=change-me-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Após `terraform apply` em infra/azure/:
# terraform output -raw swa_deploy_token
SWA_DEPLOY_TOKEN=915e4731155f093d0366c7658bcad16107241083e3016562caba24b5194627eb02-6a5aa6a2-ddf5-4f0d-bead-7ad295a1e0d300f31180608bb80f
# terraform output -raw backend_url
API_URL=https://laudifier-production-backend.azurecontainerapps.io
