# Copie para terraform.tfvars e preencha antes de aplicar.
# terraform.tfvars está no .gitignore — nunca commitar valores reais.

environment                = "prod"
fly_app_name               = "laudifier-backend"
fly_region                 = "gru"
fly_vm_memory_mb           = 1024
fly_min_machines           = 1
fly_whisper_volume_size_gb = 5
vercel_team_id             = ""
vercel_project_name        = "laudifier"
api_url                    = "https://laudifier-backend.fly.dev"
